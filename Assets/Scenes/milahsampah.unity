--- !u!114 &1142947962
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1142947961}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2069eacbc585b434e9810774775d11b0, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogPanel: {fileID: 1285320758}
  dialogText: {fileID: 1398097939}
  ekoImage: {fileID: 1788417914}
  playerBin: {fileID: 1345046039}
  spawner: {fileID: 1539613638}
  typingSpeed: 0.04
  prologLines:
  - text: '"Hai! Aku Eko, Penjaga Kebersihan kota ini."'
    expression: {fileID: 21300000, guid: aeddc1624297fd5489c323f5c9f9e5e6, type: 3}
  - text: '"Tapi belakangan ini... kota yang dulu bersih, sekarang penuh sampah berserakan."'
    expression: {fileID: 21300000, guid: a8f617a59129c1040a07e3fbff6e2999, type: 3}
  - text: '"Aku butuh bantuanmu untuk membersihkan semua ini!"'
    expression: {fileID: 21300000, guid: a8f617a59129c1040a07e3fbff6e2999, type: 3}
  - text: "\"Bantu aku arahkan dan tangkap sampah yang jatuh \u2014 masukkan ke tong
      yang tepat sebelum menyentuh tanah!\""
    expression: {fileID: 21300000, guid: aeddc1624297fd5489c323f5c9f9e5e6, type: 3}
  - text: '"Kalau jenis sampahnya makin banyak, kamu bisa ganti tong yang sedang
      dibawa lewat tombol di bawah layar."'
    expression: {fileID: 21300000, guid: aeddc1624297fd5489c323f5c9f9e5e6, type: 3}
  - text: '"Gampang kok! Ayo kita mulai bersihkan Taman Kota ini sekarang!"'
    expression: {fileID: 21300000, guid: 74c4b92276ca07f47815df9197baa377, type: 3}
  - text: '"Selamat datang di Taman Kota! Ini langkah pertama kita. Ayo bersihkan
      bersama!"'
    expression: {fileID: 21300000, guid: 74c4b92276ca07f47815df9197baa377, type: 3}
  epilogLines:
  - text: '"Kerja bagus! Pabrik dan Taman Kota sekarang sudah bersih dari sampah."'
    expression: {fileID: 21300000, guid: 74c4b92276ca07f47815df9197baa377, type: 3}
  - text: '"Terima kasih sudah membantuku memilah sampah dengan benar."'
    expression: {fileID: 21300000, guid: aeddc1624297fd5489c323f5c9f9e5e6, type: 3}
  - text: '"Mari terus jaga lingkungan kita! Sampai jumpa lagi!"'
    expression: {fileID: 21300000, guid: aeddc1624297fd5489c323f5c9f9e5e6, type: 3}
